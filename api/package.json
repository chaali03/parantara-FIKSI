{
  "name": "danamasjid-api",
  "version": "1.0.0",
  "description": "API for Dana Masjid with ElysiaJS",
  "module": "src/index.ts",
  "type": "module",
  "scripts": {
      "dev": "bun run --hot src/index.ts",
      "build": "bun build src/index.ts --outdir ./dist",
      "start": "bun run ./dist/index.js",
      "migrate": "bun run src/db/migrate.ts",
      "seed": "bun run src/db/seed.ts",
      "test": "bun test",
      "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.1",
    "@elysiajs/swagger": "^1.3.1",
    "@sinclair/typebox": "^0.34.48",
    "bcryptjs": "^3.0.3",
    "elysia": "^1.4.25",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.18.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/bun": "^1.3.9",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/pg": "^8.16.0",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "typescript": "^5.0.0"
  }
}